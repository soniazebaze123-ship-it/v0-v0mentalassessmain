# Copy this file to .env.local and replace the placeholder values.
# Do not commit real secrets.

# Public Supabase config used by the client.
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here

# Optional legacy alias used by some setups.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_publishable_key_here

# Server-only translation provider config.
QWEN_API_KEY=your_qwen_or_dashscope_api_key_here
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Alternative server-only secret name supported by the app.
# DASHSCOPE_API_KEY=your_qwen_or_dashscope_api_key_here